# /etc/multipath.conf para nodos PVE que usan el plugin zfsiscsimp con targets LIO.
# Clave: user_friendly_names no (el plugin resuelve por WWID / by-id).

defaults {
    user_friendly_names   no
    # Only WWIDs explicitly admitted by activate_volume are mapped. This is
    # critical on PVE hosts which also have local sdX disks.
    find_multipaths       strict
    polling_interval      1
    max_polling_interval  1
}

blacklist {
    # Default-deny at the same matching level as the LIO exception below;
    # never rely on unstable sdX enumeration to distinguish local disks.
    device {
        vendor  ".*"
        product ".*"
    }
}

blacklist_exceptions {
    device {
        vendor  "LIO-ORG"
        product ".*"
    }
}

# Opcional: afinar por-device para LIO
devices {
    device {
        vendor              "LIO-ORG"
        product             ".*"
        path_grouping_policy multibus
        path_selector       "round-robin 0"
        path_checker        tur
        prio                alua
        failback            immediate
        no_path_retry       60
        fast_io_fail_tmo    2
        # no_path_retry * polling_interval is 60s; keep dev_loss above it.
        dev_loss_tmo        70
        rr_min_io_rq        1
        retain_attached_hw_handler yes
    }
}
